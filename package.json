{
  "name": "solpilot",
  "version": "0.1.0",
  "description": "SolPilot is a Telegram-based AI trading assistant for the Solana ecosystem.",
  "main": "dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "dev": "ts-node-dev --transpile-only src/index.ts",
    "web": "ts-node-dev --transpile-only src/server.ts",
    "build": "tsc",
    "db:migrate": "prisma migrate dev",
    "db:seed": "prisma db seed",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "seed": "ts-node --compiler-options {\"module\":\"CommonJS\"} prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@solana/web3.js": "^1.73.0",
    "bullmq": "^5.76.10",
    "dotenv": "^16.3.1",
    "express": "^4.18.3",
    "express-rate-limit": "^8.5.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "openai": "^4.8.0",
    "pg": "^8.21.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "prom-client": "^15.1.3",
    "redis": "^5.12.1",
    "sqlite": "^5.1.1",
    "sqlite3": "^6.0.1",
    "telegraf": "^4.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^4.17.19",
    "@types/pg": "^8.20.0",
    "@types/sqlite3": "^3.1.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.0"
  }
}
